#!/bin/bash

selected=$(echo "茶릩 Power Options
 Relaunch Options
箚즴 Application Launcher
箚쾶 Terminal Application Launcher
箚뼗 Web Search" | rofi -dmenu)


case $selected in
	"茶릩 Power Options") ~/.config/rofi/bin/power ;;
	" Relaunch Options") ~/.config/rofi/bin/restart ;;
	"箚즴 Application Launcher") rofi -show drun ;;
	"箚쾶 Terminal Application Launcher") rofi -show run ;;
	"箚뼗 Web Search") ~/.config/rofi/bin/web ;;
esac
